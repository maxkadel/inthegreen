<div class="container">
  <h1>Expenses</h1>

  <table class="table">
    <thead>
      <th scope="col">Expense name</th>
      <th scope="col">Amount due</br>(fixed)</th>
      <th scope="col">Amount due</br>(range - low)</th>
      <th scope="col">Amount due</br>(range - high)</th>
      <th scope="col">Next due date</th>
      <th scope="col">Recurrence</th>
    </thead>

    <% @expenses.each do |expense| %>
      <tr>
        <td>
          <%= link_to expense.expense_name, expense_path(expense) %>
        </td>
        <td>
          <%= number_to_currency(expense.amount_due_fixed) %>
        </td>
        <td>
          <%= number_to_currency(expense.amount_due_range_low) %>
        </td>
        <td>
          <%= number_to_currency(expense.amount_due_range_high) %>
        </td>
        <td>
          <%= t(format_time(expense.next_due_date, :long, "N/A")) %>
        </td>
        <td>
          <%= expense.recurrence %>
        </td>
        <td><%= link_to 'Show', expense %></td>
        <td><%= link_to 'Edit', edit_expense_path(expense) %></td>
        <td><%= link_to 'Destroy', expense, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </table>
  <%= link_to 'New expense', new_expense_path, class:"btn btn-primary" %>
</div>
