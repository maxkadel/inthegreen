<div class="container">
  <h1>Expenses</h1>

  <table class="table">
    <thead>
      <th scope="col">Expense name</th>
      <th scope="col">Amount due (fixed)</th>
      <th scope="col">Amount due (range - low)</th>
      <th scope="col">Amount due (range - high)</th>
      <th scope="col">Next due date</th>
      <th scope="col">Recurrence</th>
    </thead>

    <% @expenses.each do |expense| %>
      <tr>
        <td>
          <%= link_to expense.expense_name, expense_path(expense) %>
        </td>
        <td>
          <%= expense.amount_due_fixed %>
        </td>
        <td>
          <%= expense.amount_due_range_low %>
        </td>
        <td>
          <%= expense.amount_due_range_high %>
        </td>
        <td>
          <%= expense.next_due_date %>
        </td>
        <td>
          <%= expense.recurrence %>
        </td>
      </tr>
    <% end %>
  </table>
  <%= link_to 'New expense', new_expense_path, class:"btn btn-primary" %>
</div>
